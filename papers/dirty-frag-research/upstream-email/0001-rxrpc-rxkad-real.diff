--- /tmp/rxkad-orig.c	2026-05-08 01:07:30
+++ /tmp/rxkad-patched.c	2026-05-08 01:20:41
@@ -412,10 +412,11 @@
 	struct rxkad_level1_hdr sechdr;
 	struct rxrpc_skb_priv *sp = rxrpc_skb(skb);
 	struct rxrpc_crypt iv;
-	struct scatterlist sg[16];
+	struct scatterlist sg_in[1];
+	struct scatterlist sg_out[1];
+	u8 hdr_buf[8];
 	u32 data_size, buf;
 	u16 check;
-	int ret;
 
 	_enter("");
 
@@ -423,27 +424,27 @@
 		return rxrpc_abort_eproto(call, skb, RXKADSEALEDINCON,
 					  rxkad_abort_1_short_header);
 
-	/* Decrypt the skbuff in-place.  TODO: We really want to decrypt
-	 * directly into the target buffer.
+	/* Decrypt the 8-byte security header into a stack bounce buffer.
+	 * Decrypting in-place via a scatterlist built directly from skb
+	 * pages is unsafe when those pages came from MSG_SPLICE_PAGES
+	 * (Dirty Frag, oss-security 2026-05-07).
 	 */
-	sg_init_table(sg, ARRAY_SIZE(sg));
-	ret = skb_to_sgvec(skb, sg, sp->offset, 8);
-	if (unlikely(ret < 0))
-		return ret;
+	if (skb_copy_bits(skb, sp->offset, hdr_buf, 8) < 0)
+		return rxrpc_abort_eproto(call, skb, RXKADSEALEDINCON,
+					  rxkad_abort_1_short_header);
+	sg_init_one(sg_in,  hdr_buf, 8);
+	sg_init_one(sg_out, hdr_buf, 8);
 
 	/* start the decryption afresh */
 	memset(&iv, 0, sizeof(iv));
 
 	skcipher_request_set_sync_tfm(req, call->conn->rxkad.cipher);
 	skcipher_request_set_callback(req, 0, NULL, NULL);
-	skcipher_request_set_crypt(req, sg, sg, 8, iv.x);
+	skcipher_request_set_crypt(req, sg_in, sg_out, 8, iv.x);
 	crypto_skcipher_decrypt(req);
 	skcipher_request_zero(req);
 
-	/* Extract the decrypted packet length */
-	if (skb_copy_bits(skb, sp->offset, &sechdr, sizeof(sechdr)) < 0)
-		return rxrpc_abort_eproto(call, skb, RXKADDATALEN,
-					  rxkad_abort_1_short_encdata);
+	memcpy(&sechdr, hdr_buf, sizeof(sechdr));
 	sp->offset += sizeof(sechdr);
 	sp->len    -= sizeof(sechdr);
 
@@ -461,6 +462,15 @@
 					  rxkad_abort_1_short_data);
 	sp->len = data_size;
 
+	/* Mirror decrypted plaintext back into the skb only after the
+	 * length+checksum sanity check passes.  skb_store_bits is the
+	 * standard safe-write path that COWs spliced pages instead of
+	 * writing to user-shared backing.
+	 */
+	if (skb_store_bits(skb, sp->offset - sizeof(sechdr), hdr_buf, 8) < 0)
+		return rxrpc_abort_eproto(call, skb, RXKADDATALEN,
+					  rxkad_abort_1_short_encdata);
+
 	_leave(" = 0 [dlen=%x]", data_size);
 	return 0;
 }
